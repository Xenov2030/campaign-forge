# ─────────────────────────────────────────────────────────────
# CampaignForge — Variables de entorno
# Copiá este archivo como .env.local y completá los valores.
# ─────────────────────────────────────────────────────────────

# ── Modo mock (sin base de datos) ─────────────────────────────
# Poné MOCK_MODE=true para desarrollar sin conectarte a Postgres.
# Los datos se guardan en data/mock-db.json (ignorado por git).
# Usuarios de prueba: master@demo.com / player@demo.com (cualquier contraseña)
MOCK_MODE=true

# ── Base de datos (necesario solo si MOCK_MODE=false) ─────────
# Obtené la URL de conexión en https://neon.tech (plan gratuito)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth ──────────────────────────────────────────────────────
# Secreto para firmar los JWT de sesión. Cambiá esto en producción.
JWT_SECRET=campaign-forge-dev-secret-change-in-production

# ── OpenAI (opcional, para IA Forge y Asistente del Máster) ──
OPENAI_API_KEY=sk-...
