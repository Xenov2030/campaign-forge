# ─────────────────────────────────────────────────────────────────────────────
# CampaignForge — Variables de entorno
# Copiá este archivo como .env.local y completá los valores.
# ─────────────────────────────────────────────────────────────────────────────

# ── Modo de desarrollo (sin base de datos) ────────────────────────────────────
# MOCK_MODE=true  → la app funciona sin Postgres, datos en data/mock-db.json
# MOCK_MODE=false → conecta a la DB real (completar DATABASE_URL y las demás vars)
#
# Usuarios de prueba en modo mock:
#   master@demo.com  /  player@demo.com  (cualquier contraseña)
MOCK_MODE=true

# ── Base de datos ─────────────────────────────────────────────────────────────
# Solo necesario cuando MOCK_MODE=false.
# Obtené la URL de conexión en https://neon.tech (plan gratuito disponible).
# Formato: postgresql://usuario:contraseña@host/nombre_db?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
# Secreto para firmar tokens de sesión. Mínimo 32 caracteres.
# Cambiá este valor en producción — nunca uses el de ejemplo.
JWT_SECRET=campaign-forge-dev-secret-change-in-production

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Necesario para IA Forge (generación de NPCs, locaciones, etc.)
# y para el Asistente del Máster (GPT-4o contextual).
# Obtené tu clave en https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── URL pública de la app ─────────────────────────────────────────────────────
# Usada en redirects de auth y en el demo login.
# En desarrollo local: http://localhost:3000
# En producción: tu dominio completo (ej: https://campaignforge.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Cloudinary (imágenes) ─────────────────────────────────────────────────────
# Necesario para upload real de imágenes (avatares, galería).
# Por ahora es opcional — la feature de upload no está completamente integrada.
# Obtené las credenciales en https://cloudinary.com → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ── Supabase (Realtime — chat en tiempo real) ─────────────────────────────────
# Solo necesario cuando MOCK_MODE=false y para habilitar chat en tiempo real.
# Obtené los valores en tu proyecto de Supabase → Settings → API
# NEXT_PUBLIC_SUPABASE_URL y NEXT_PUBLIC_SUPABASE_ANON_KEY son públicas (browser).
# SUPABASE_SERVICE_ROLE_KEY es privada (solo servidor).
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── LiveKit (canales de voz) ──────────────────────────────────────────────────
# Necesario para activar los canales de voz.
# Podés usar LiveKit Cloud (https://livekit.io) o auto-hosted.
# NEXT_PUBLIC_LIVEKIT_URL es la URL WebSocket pública (ej: wss://tu-app.livekit.cloud)
NEXT_PUBLIC_LIVEKIT_URL=wss://tu-app.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=your-livekit-secret
