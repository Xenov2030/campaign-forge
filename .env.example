# ── Base de datos (PostgreSQL en la nube — Neon recomendado) ──────────────────
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Auth JWT ──────────────────────────────────────────────────────────────────
# Genera uno seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="reemplaza-con-un-secreto-largo-y-aleatorio"

# ── Gemini (opcional — las funciones IA quedan desactivadas si no se pone) ────
# Obtené tu clave en https://aistudio.google.com/apikey
GEMINI_API_KEY="..."

# ── Cloudinary (subida de imágenes) ──────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

# ── Pusher (chat en tiempo real) ─────────────────────────────────────────────
# Crear app gratuita en https://pusher.com → Channels
PUSHER_APP_ID="tu-app-id"
PUSHER_SECRET="tu-secret"
NEXT_PUBLIC_PUSHER_KEY="tu-key"
NEXT_PUBLIC_PUSHER_CLUSTER="us2"   # o mt1, eu, ap1, etc. según tu región

# ── LiveKit (chat de voz) ─────────────────────────────────────────────────────
# Crear proyecto en https://livekit.io
LIVEKIT_API_KEY="APIxxxxxxxxxx"
LIVEKIT_API_SECRET="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_LIVEKIT_URL="wss://tu-proyecto.livekit.cloud"

# ── URL de la app ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://tu-sitio.vercel.app"
